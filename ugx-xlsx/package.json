{
  "name": "ugx-xlsx",
  "version": "0.1.1",
  "description": "Safe, TypeScript-first Excel utilities (JSON → XLSX/CSV) for Angular and modern web.",
  "private": false,
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/esm2020/index.d.ts",
      "es2020": "./dist/esm2020/index.js",
      "import": "./dist/esm2015/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm2015/index.js",
  "es2020": "dist/esm2020/index.js",
  "types": "dist/esm2020/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:esm2020 && npm run build:esm2015 && npm run build:cjs",
    "build:esm2020": "tsc -p tsconfig.esm2020.json",
    "build:esm2015": "tsc -p tsconfig.esm2015.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "clean": "rimraf dist",
    "test": "vitest run",
    "prepare": "npm run build"
  },
  "keywords": [
    "excel",
    "xlsx",
    "csv",
    "angular",
    "typescript",
    "export"
  ],
  "license": "MIT",
  "dependencies": {
    "exceljs": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
