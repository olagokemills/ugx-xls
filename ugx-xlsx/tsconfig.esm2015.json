{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2015",
    "module": "ES2015",
    "lib": ["ES2015", "DOM"],
    "declaration": true,
    "declarationDir": "dist/esm2015",
    "outDir": "dist/esm2015",
    "rootDir": "src",
    "downlevelIteration": true,
    "noEmit": false
  },
  "include": ["src/**/*"],
  "exclude": ["test", "tests", "**/*.spec.ts"]
}
